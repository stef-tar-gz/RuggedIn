{
  "expo": {
    "name": "RuggedIn",
    "slug": "ruggedin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ruggedin",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ruggedin",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "RuggedIn vuole accedere alle tue foto per impostare l'immagine del profilo."
        }
      ],
      "@react-native-community/datetimepicker",
      "react-native-reanimated/plugin",
      "@shopify/react-native-skia"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78fd3520-18a5-4451-b8fa-22a2b08eae9b"
      }
    }
  }
}
